# Inno Fantasy backend environment template.
#
# Copy this file to `.env` on the VM/local backend host and fill the values
# there. Do not commit the real `.env` file.

# API-Football secret.
# Use either APISPORTS_KEY or API_FOOTBALL_KEY. APISPORTS_KEY is preferred
# because API-Football documents that header name.
APISPORTS_KEY=<api_football_key>
# API_FOOTBALL_KEY=<api_football_key>

# OCI auth / guardrail credentials
# Required by backend/config/config.yaml unless that config is edited directly.
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..your_compartment_ocid
OCI_PROJECT=ocid1.generativeaiproject.oc1..your_project_ocid

# OCI OpenAI-compatible client requires an api_key field, but user-principal auth
# is handled by the OCI config/profile. Leave this as not-used unless your setup changes.
OCI_AI_API_KEY=not-used

# Admin-only backend actions
# Required only for protected admin routes such as manual rescoring:
# POST /scores/{job_id}/score
# The normal UI flow does not need this token.
INNO_FANTASY_ADMIN_TOKEN=<long_random_admin_token>
