# API-Football secret
# Use either APISPORTS_KEY or API_FOOTBALL_KEY.
APISPORTS_KEY=your_api_football_key_here

# OCI auth / guardrail credentials
# Keep these only if your local/VM OCI setup needs env-driven values.
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..your_compartment_ocid
OCI_PROJECT=ocid1.generativeaiproject.oc1..your_project_ocid

# OCI OpenAI-compatible client requires an api_key field, but user-principal auth
# is handled by the OCI config/profile. Leave this as not-used unless your setup changes.
OCI_AI_API_KEY=not-used