# Inno Fantasy final app bound to the existing edge_agentapp route.
# Public web/proxy server default: 127.0.0.1:6004
# Internal FastAPI backend default: 127.0.0.1:10006

client_max_body_size 25m;

location = /edge_agentapp {
    return 301 /edge_agentapp/;
}

location ^~ /edge_agentapp/ {
    proxy_pass http://127.0.0.1:6004/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}
