{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Risk Play Answer",
  "oneOf": [
    {
      "type": "null"
    },
    {
      "type": "object",
      "required": ["claim_id"],
      "properties": {
        "claim_id": {
          "type": "string"
        },
        "match_id": {
          "type": "string"
        },
        "team_id": {
          "type": "string"
        },
        "player_id": {
          "type": "string"
        },
        "home_score": {
          "type": "integer"
        },
        "away_score": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  ]
}
